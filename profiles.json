
{
  "default": "kr",
  "globals": {
    "headless": false,

    "width": 1000,
    "height": 1000,

    "enableMemReport": true,
    "memReportIntervalMs": 30000,

    "baseChromeArgs": [
      "--disable-dev-shm-usage",
      "--no-first-run",
      "--no-default-browser-check",
      "--disable-infobars",
      "--start-maximized"
    ],

    "ui": {
      "defaultViewportNull": true
    },

    "mobile": {
      "enabled": true,
      "viewport": {
        "width": 1000,
        "height": 1000,
        "deviceScaleFactor": 2,
        "isMobile": true,
        "hasTouch": true,
        "isLandscape": false
      },
      "userAgent": "Mozilla/5.0 (Linux; Android 13; Pixel 7) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Mobile Safari/537.36"
    }
  },
  "profiles": {
